# Copy this file to .streamlit/secrets.toml (local) or paste its contents
# into the Streamlit Cloud "Secrets" settings for the deployed app.
OPENROUTER_API_KEY = "sk-or-your-openrouter-key-here"

# Persistent database (required on Streamlit Cloud — its disk is wiped on
# every restart). Create a free database at https://turso.tech, then run:
#   turso db show <db-name> --url     -> TURSO_DATABASE_URL
#   turso db tokens create <db-name>  -> TURSO_AUTH_TOKEN
# Leave these out to use a local er_checker.db file instead (local dev).
TURSO_DATABASE_URL = "libsql://your-db-name-your-org.turso.io"
TURSO_AUTH_TOKEN = "your-turso-auth-token"
